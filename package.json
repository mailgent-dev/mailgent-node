{
  "name": "@mailgent-dev/sdk",
  "version": "0.7.0",
  "description": "Official Node.js SDK for the Mailgent API \u2014 identity infrastructure for AI agents and buyer-side x402 payments",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./webhook": {
      "import": {
        "types": "./dist/webhook.d.mts",
        "default": "./dist/webhook.mjs"
      },
      "require": {
        "types": "./dist/webhook.d.ts",
        "default": "./dist/webhook.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mailgent",
    "ai",
    "agent",
    "email",
    "mcp",
    "did",
    "vault",
    "sdk",
    "x402",
    "usdc",
    "payments"
  ],
  "license": "MIT",
  "author": "Mailgent",
  "homepage": "https://mailgent.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mailgent-dev/mailgent-node.git"
  },
  "bugs": {
    "url": "https://github.com/mailgent-dev/mailgent-node/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "express": ">=4"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
